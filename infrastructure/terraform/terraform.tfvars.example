# General
project_name = "sentinel"
environment  = "dev"
region       = "ap-south-1"

# VPC
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["ap-south-1a", "ap-south-1b"]
enable_ha_nat      = false  # Set to true for production HA

# RDS
db_instance_class = "db.t3.medium"
db_multi_az       = false   # Set to true for production
db_password       = ""      # Leave empty to auto-generate and store in Secrets Manager

# ALB SSL (provide ACM certificate ARN for HTTPS)
acm_certificate_arn = ""    # e.g., "arn:aws:acm:ap-south-1:123456789012:certificate/abc-123"

# CloudFront (certificate must be in ap-south-1)
cloudfront_acm_certificate_arn = ""  # e.g., "arn:aws:acm:ap-south-1:123456789012:certificate/abc-123"
domain_aliases                 = []  # e.g., ["app.sentinel.example.com"]

# Application
jwt_secret            = "change-me-to-a-secure-random-string"
firebase_database_url = ""  # e.g., "https://your-project.firebaseio.com"
