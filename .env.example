# Database
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
DATABASE_URL_SYNC=postgresql://sentinel:sentinel@localhost:5432/sentinel

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS / LocalStack
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
SQS_INGESTION_QUEUE=sentinel-ingestion-jobs
SQS_AI_PIPELINE_QUEUE=sentinel-ai-pipeline
SQS_NOTIFICATIONS_QUEUE=sentinel-notifications
SNS_TENANT_EVENTS_TOPIC=sentinel-tenant-events
S3_REPORTS_BUCKET=sentinel-reports
S3_UPLOADS_BUCKET=sentinel-uploads

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AWS_BEDROCK_REGION=ap-south-1

# Services
API_GATEWAY_PORT=8000
AUTH_SERVICE_URL=http://auth-service:8001
TENANT_SERVICE_URL=http://tenant-service:8002
INGESTION_SERVICE_URL=http://ingestion-service:8003
ANALYTICS_SERVICE_URL=http://analytics-service:8005
CAMPAIGN_SERVICE_URL=http://campaign-service:8006
NOTIFICATION_SERVICE_URL=http://notification-service:8007
LOGGING_SERVICE_URL=http://logging-service:8008

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
NEXT_PUBLIC_FIREBASE_CONFIG={}

# Redis
REDIS_URL=redis://localhost:6379

# Sentry
# When using self-hosted Sentry (--profile sentry), DSN format:
#   http://<key>@sentry-web:9000/<project-id>  (for containerized services)
#   http://<key>@localhost:9000/<project-id>    (for host access)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SECRET_KEY=super-secret-change-me-in-production

# Logging
LOG_SHIPPING_ENABLED=true

# Voter Service (Claude API for voter list extraction)
CLAUDE_VOTER_MODEL_ID=claude-sonnet-4-20250514
VOTER_PAGES_PER_CHUNK=5
